# ── Cloud sync (Supabase) ──────────────────────────────────────────
# Copy this file to `.env.local` and fill in your project's values.
# Find both under: Supabase Dashboard → Project Settings → API.
#
# These are PUBLIC values (safe to expose in the browser). Data is
# protected by Row Level Security, not by hiding the anon key.
#
# Leaving these unset runs the app in local-only mode (browser storage),
# exactly as it behaved before cloud sync was added.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
